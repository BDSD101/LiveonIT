    "start": "node dist/server.js"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.5.0",
    "dotenv": "^16.6.1",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
